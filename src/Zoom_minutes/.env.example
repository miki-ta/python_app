# ============================================================
# .env.example
# このファイルを .env にコピーして、自分の設定を記入してください。
#   cp .env.example .env
# ============================================================

# ── API キー ────────────────────────────────────────────────
# OpenAI APIキー (Whisper 文字起こし用)
# 取得: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Anthropic APIキー (Claude 議事録生成用)
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── メール設定 (Gmail の場合) ────────────────────────────────
# Gmail を使う場合:
#   Google アカウント → セキュリティ → 2段階認証を有効化
#   → アプリパスワードを生成して SENDER_PASSWORD に設定
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 受信者 (複数の場合はカンマ区切り)
RECIPIENTS=member1@example.com,member2@example.com
